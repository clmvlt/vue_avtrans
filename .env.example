# API Backend URL
VITE_API_URL=http://localhost:8081/

# Google Identity Services — client ID public (le secret reste côté backend uniquement)
VITE_GOOGLE_CLIENT_ID=

# Mapbox token (optionnel - un token par défaut est fourni dans src/config/map.ts)
# VITE_MAPBOX_TOKEN=votre_token_mapbox_ici

# API de géocodage (autocomplétion d'adresse — Base Adresse Nationale)
VITE_GEOCODING_API_URL=https://ors.stack.bzh/
